#!/usr/bin/env bash
#===============================================================================
# N0DM - Enhanced Yadm Wrapper for Arch Linux
# Version: 1.1.0
# Combines Yadm's reliability with smart backups and safety features
#===============================================================================
set -euo pipefail

#--- Configuration -------------------------------------------------------------
readonly N0DM_VERSION="1.1.0"
readonly N0DM_UPDATE_URL="https://raw.githubusercontent.com/noeltz/n0dm/main/n0dm"
readonly N0DM_DATA_DIR="${HOME}/.local/share/n0dm"
readonly N0DM_BACKUP_DIR="${N0DM_DATA_DIR}/backups"
readonly N0DM_CONFIG="${N0DM_DATA_DIR}/config"
readonly N0DM_STATE_FILE="${N0DM_DATA_DIR}/state"
readonly MAX_BACKUPS="${N0DM_MAX_BACKUPS:-10}"
readonly BACKUP_RETENTION_DAYS="${N0DM_BACKUP_RETENTION:-30}"

#--- Colors & Output -----------------------------------------------------------
readonly RESET='\033[0m' BOLD='\033[1m' RED='\033[31m' GREEN='\033[32m'
readonly YELLOW='\033[33m' BLUE='\033[34m' MAGENTA='\033[35m' CYAN='\033[36m'
readonly CHECK='✓' CROSS='✗' ARROW='➜' WARN='⚠' INFO='ℹ'

print_ok()    { echo -e "${GREEN}${CHECK}${RESET} $*"; }
print_err()   { echo -e "${RED}${CROSS}${RESET} $*" >&2; }
print_info()  { echo -e "${BLUE}${ARROW}${RESET} $*"; }
print_warn()  { echo -e "${YELLOW}${WARN}${RESET} $*"; }
print_notice(){ echo -e "${MAGENTA}${INFO}${RESET} $*"; }

#--- Helpers -------------------------------------------------------------------
ensure_dirs() {
    mkdir -p "$N0DM_BACKUP_DIR" "$(dirname "$N0DM_CONFIG")" "$(dirname "$N0DM_STATE_FILE")"
}

load_config() {
    if [[ -f "$N0DM_CONFIG" ]]; then
        source "$N0DM_CONFIG"
    fi
}

save_config() {
    cat > "$N0DM_CONFIG" <<EOF
# N0DM config (auto-generated)
MAX_BACKUPS=${MAX_BACKUPS}
BACKUP_RETENTION_DAYS=${BACKUP_RETENTION_DAYS}
EOF
}

timestamp() { date +"%Y%m%d_%H%M%S"; }
epoch_time() { date +%s; }

check_yadm() {
    if ! command -v yadm &> /dev/null; then
        print_err "Yadm not found. Install with: sudo pacman -S yadm"
        exit 1
    fi
}

get_yadm_git_dir() {
    echo "${HOME}/.local/share/yadm/repo.git"
}

#--- State Management for Smart Backups ----------------------------------------
get_last_backup_epoch() {
    if [[ -f "$N0DM_STATE_FILE" ]]; then
        grep "^last_backup_epoch=" "$N0DM_STATE_FILE" 2>/dev/null | cut -d= -f2 || echo "0"
    else
        echo "0"
    fi
}

set_last_backup_epoch() {
    local epoch="$1"
    mkdir -p "$(dirname "$N0DM_STATE_FILE")"
    # Update or add the value
    if grep -q "^last_backup_epoch=" "$N0DM_STATE_FILE" 2>/dev/null; then
        sed -i "s/^last_backup_epoch=.*/last_backup_epoch=${epoch}/" "$N0DM_STATE_FILE"
    else
        echo "last_backup_epoch=${epoch}" >> "$N0DM_STATE_FILE"
    fi
}

#--- Smart Backup Detection ----------------------------------------------------
# Returns 0 (true) if tracked files have changed since last backup
needs_smart_backup() {
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    local last_backup_epoch; last_backup_epoch=$(get_last_backup_epoch)
    
    # If no previous backup, always backup on first sync
    if [[ "$last_backup_epoch" -eq 0 ]]; then
        return 0
    fi
    
    # Check if any tracked file was modified after last backup
    cd "$HOME" || return 1
    while IFS= read -r -d '' file; do
        [[ -z "$file" ]] && continue
        local full_path="${HOME}/${file}"
        # Skip if file doesn't exist in home (might be repo-only)
        [[ ! -e "$full_path" ]] && continue
        # Get file modification time
        local file_mtime; file_mtime=$(stat -c %Y "$full_path" 2>/dev/null || echo "0")
        if [[ "$file_mtime" -gt "$last_backup_epoch" ]]; then
            return 0  # Change detected
        fi
    done < <(git --git-dir="$yadm_git_dir" --work-tree="$HOME" ls-files -z 2>/dev/null)
    
    return 1  # No changes detected
}

#--- Backup System -------------------------------------------------------------
create_backup() {
    local label="${1:-manual}"
    local ts; ts=$(timestamp)
    local epoch; epoch=$(epoch_time)
    local backup_dir="${N0DM_BACKUP_DIR}/${ts}_${label}"
    
    print_info "Creating backup: ${backup_dir#$HOME/}"
    mkdir -p "$backup_dir"
    
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    
    if [[ ! -d "$yadm_git_dir" ]]; then
        print_err "Yadm repository not found. Run 'n0dm init' first."
        return 1
    fi
    
    # Use git archive to export tracked files cleanly
    cd "$HOME"
    git --git-dir="$yadm_git_dir" --work-tree="$HOME" ls-files -z | \
        xargs -0 -I{} sh -c 'mkdir -p "$(dirname "$backup_dir/{}")" && cp -a "{}" "$backup_dir/{}"'
    
    # Store metadata
    cat > "${backup_dir}/.n0dm-meta" <<EOF
timestamp=$ts
epoch=$epoch
label=$label
yadm_branch=$(git --git-dir="$yadm_git_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
n0dm_version=${N0DM_VERSION}
EOF
    
    # Update state file with backup epoch
    set_last_backup_epoch "$epoch"
    
    # Cleanup old backups (smart retention)
    cleanup_backups
    
    print_ok "Backup created: $(basename "$backup_dir")"
    echo "$backup_dir"
}

list_backups() {
    if [[ ! -d "$N0DM_BACKUP_DIR" ]] || [[ -z "$(ls -A "$N0DM_BACKUP_DIR" 2>/dev/null)" ]]; then
        print_warn "No backups found"
        return 1
    fi
    
    echo -e "\n${BOLD}Available Backups:${RESET}"
    printf "%-30s %-15s %-10s %s\n" "BACKUP ID" "DATE" "EPOCH" "LABEL"
    printf "%-30s %-15s %-10s %s\n" "$(printf '%.0s-' {1..30})" "$(printf '%.0s-' {1..15})" "$(printf '%.0s-' {1..10})" "$(printf '%.0s-' {1..10})"
    
    find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort -r | while read -r backup; do
        local ts="${backup:0:15}"
        local label="${backup:16}"
        local date_fmt="${ts:0:4}-${ts:4:2}-${ts:6:2} ${ts:9:2}:${ts:11:2}"
        # Extract epoch from metadata if available
        local epoch="N/A"
        if [[ -f "${N0DM_BACKUP_DIR}/${backup}/.n0dm-meta" ]]; then
            epoch=$(grep "^epoch=" "${N0DM_BACKUP_DIR}/${backup}/.n0dm-meta" 2>/dev/null | cut -d= -f2 || echo "N/A")
        fi
        printf "%-30s %-15s %-10s %s\n" "$backup" "$date_fmt" "$epoch" "$label"
    done
    echo
}

restore_backup() {
    local backup_id="$1"
    local backup_dir="${N0DM_BACKUP_DIR}/${backup_id}"
    
    if [[ ! -d "$backup_dir" ]]; then
        print_err "Backup not found: $backup_id"
        list_backups
        return 1
    fi
    
    print_warn "This will overwrite tracked files in your home directory"
    if [[ "${N0DM_YES:-false}" != "true" ]]; then
        read -p "Proceed with restore? [y/N] " -n 1 -r
        echo
        [[ $REPLY =~ ^[Yy]$ ]] || { print_info "Restore cancelled"; return 0; }
    fi
    
    # Create safety backup first (always, regardless of smart logic)
    print_info "Creating safety backup before restore..."
    create_backup "pre-restore" >/dev/null
    
    # Restore files
    print_info "Restoring from: $backup_id"
    cd "$backup_dir"
    find . -type f ! -name '.n0dm-meta' -exec sh -c '
        rel="${1#./}"
        [[ -n "$rel" ]] && { mkdir -p "$HOME/$(dirname "$rel")" && cp -a "$1" "$HOME/$rel"; }
    ' _ {} \;
    
    print_ok "Restore completed!"
    print_info "Run 'n0dm status' or 'yadm status' to verify"
}

cleanup_backups() {
    [[ ! -d "$N0DM_BACKUP_DIR" ]] && return 0
    
    local now; now=$(epoch_time)
    local retention_secs=$((BACKUP_RETENTION_DAYS * 86400))
    local count=0 removed=0
    
    # Sort by name (timestamp) descending, keep newest MAX_BACKUPS
    find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort -r | while read -r backup; do
        ((count++))
        local backup_path="${N0DM_BACKUP_DIR}/${backup}"
        local backup_time; backup_time=$(stat -c %Y "$backup_path" 2>/dev/null || echo 0)
        local age=$((now - backup_time))
        
        # Remove if too old OR beyond max count
        if ((age > retention_secs)) || ((count > MAX_BACKUPS)); then
            rm -rf "$backup_path"
            print_info "Removed old backup: $backup"
            ((removed++))
        fi
    done
    
    [[ $removed -gt 0 ]] && print_ok "Cleanup: removed $removed backup(s)"
}

#--- Safe Sync Wrapper with Smart Backup ---------------------------------------
n0dm_safe_sync() {
    local message="${1:-Auto-sync}"
    local no_backup="${2:-false}"
    local dry_run="${3:-false}"
    
    # Check yadm is initialized
    if ! yadm status &>/dev/null; then
        print_err "Yadm not initialized. Run 'n0dm init' first."
        return 1
    fi
    
    # Smart backup: only create if tracked files changed AND backup not disabled
    if [[ "$no_backup" != "true" && "$dry_run" != "true" ]]; then
        if needs_smart_backup; then
            print_info "Changes detected in tracked files, creating pre-sync backup..."
            create_backup "pre-sync" >/dev/null
        else
            print_info "No changes in tracked files, skipping backup"
        fi
    fi
    
    # Dry run mode
    if [[ "$dry_run" == "true" ]]; then
        print_info "=== DRY RUN ==="
        yadm status --short
        print_info "=== END DRY RUN ==="
        return 0
    fi
    
    # Pull with conflict detection
    print_info "Pulling remote changes..."
    if ! yadm pull --ff-only 2>/dev/null; then
        print_warn "Fast-forward pull failed. Checking for conflicts..."
        if yadm merge --no-commit --no-ff origin/$(yadm branch --show-current) 2>&1 | grep -q "CONFLICT"; then
            print_err "Merge conflicts detected!"
            print_info "Resolve with: n0dm mergetool"
            print_info "Then run: n0dm sync to complete"
            return 1
        fi
    fi
    
    # Commit local changes if any
    if [[ -n "$(yadm status --porcelain)" ]]; then
        print_info "Committing local changes..."
        yadm add -A
        yadm commit -m "$message" || print_warn "Nothing to commit"
    fi
    
    # Push
    if yadm remote get-url origin &>/dev/null; then
        print_info "Pushing to remote..."
        yadm push || {
            print_err "Push failed. Your changes are committed locally."
            return 1
        }
        print_ok "Sync complete!"
    fi
    
    # Post-sync cleanup (always run to maintain retention)
    cleanup_backups
    return 0
}

#--- Conflict Helper -----------------------------------------------------------
n0dm_check_conflicts() {
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)

    if [[ -n "$(git --git-dir="$yadm_git_dir" diff --name-only --diff-filter=U 2>/dev/null)" ]]; then
        print_err "Unresolved merge conflicts:"
        git --git-dir="$yadm_git_dir" diff --name-only --diff-filter=U
        echo
        print_info "Resolve with: n0dm mergetool"
        return 1
    fi
    return 0
}

#--- Connect to Remote ---------------------------------------------------------
n0dm_connect() {
    local repo="${1:-}"
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)

    if [[ ! -d "$yadm_git_dir" ]]; then
        print_err "Yadm repository not found. Run 'n0dm init' first."
        return 1
    fi

    # Check if remote already exists
    local existing_remote
    existing_remote=$(git --git-dir="$yadm_git_dir" remote get-url origin 2>/dev/null || echo "")
    if [[ -n "$existing_remote" ]]; then
        print_warn "Remote already configured: $existing_remote"
        if [[ "${N0DM_YES:-false}" != "true" ]]; then
            read -p "Replace it? [y/N] " -n 1 -r
            echo
            [[ $REPLY =~ ^[Yy]$ ]] || { print_info "Keeping existing remote"; return 0; }
        fi
    fi

    # If no repo specified, prompt for it
    if [[ -z "$repo" ]]; then
        print_info "Connect to a GitHub repository"
        echo "  Format: username/repo  (e.g., alice/dotfiles)"
        echo "  Or full URL: https://github.com/alice/dotfiles.git"
        echo
        read -p "Repository: " -r repo
    fi

    [[ -z "$repo" ]] && { print_err "No repository specified"; return 1; }

    # Convert short form to GitHub URL if needed
    local remote_url
    if [[ "$repo" =~ ^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$ ]]; then
        remote_url="https://github.com/${repo}.git"
    elif [[ "$repo" =~ ^git@github\.com: ]]; then
        remote_url="$repo"
    elif [[ "$repo" =~ ^https?:// ]]; then
        remote_url="$repo"
    else
        print_err "Invalid repository format. Use 'username/repo' or full URL."
        return 1
    fi

    # Add or set the remote
    if [[ -n "$existing_remote" ]]; then
        git --git-dir="$yadm_git_dir" remote set-url origin "$remote_url"
    else
        git --git-dir="$yadm_git_dir" remote add origin "$remote_url"
    fi

    print_ok "Remote configured: $remote_url"
    print_info "Next steps:"
    echo "  1. Create the repository on GitHub (if not exists)"
    echo "  2. Run: n0dm push -u origin"
}

#--- Atomic Self-Update --------------------------------------------------------
self_update() {
    print_info "Checking for updates..."
    
    local script_path; script_path=$(realpath "$0")
    local script_dir; script_dir=$(dirname "$script_path")
    local temp_file; temp_file=$(mktemp -p "$script_dir" .n0dm-update.XXXXXX)
    
    if curl -fsSL "$N0DM_UPDATE_URL" -o "$temp_file" 2>/dev/null; then
        local current_version; current_version=$(grep "^readonly N0DM_VERSION=" "$script_path" | head -1 | cut -d'"' -f2)
        local new_version; new_version=$(grep "^readonly N0DM_VERSION=" "$temp_file" | head -1 | cut -d'"' -f2)
        
        [[ -z "$current_version" ]] && current_version="unknown"
        [[ -z "$new_version" ]] && { print_err "Failed to determine remote version"; rm -f "$temp_file"; return 1; }
        
        if [[ "$new_version" != "$current_version" ]]; then
            print_info "New version available: $new_version (current: $current_version)"
            if [[ "${N0DM_YES:-false}" == "true" ]]; then
                auto_confirm="y"
            else
                read -p "Install update? [y/N] " -n 1 -r auto_confirm
                echo
            fi
            
            if [[ $auto_confirm =~ ^[Yy]$ ]]; then
                chmod +x "$temp_file"
                if mv "$temp_file" "$script_path"; then
                    print_ok "Updated to version $new_version"
                    print_info "Restarting n0dm..."
                    exec "$script_path" version
                else
                    print_err "Failed to install update"; rm -f "$temp_file"; return 1
                fi
            else
                rm -f "$temp_file"; print_info "Update cancelled"
            fi
        else
            print_ok "Already running the latest version ($current_version)"
            rm -f "$temp_file"
        fi
    else
        print_err "Failed to check for updates"
        print_info "Make sure you have internet connectivity"
        rm -f "$temp_file"; return 1
    fi
}

#--- Yadm Passthrough (ALL native commands) ------------------------------------
# This function passes ANY command directly to yadm, preserving all native behavior
yadm_passthrough() {
    check_yadm
    yadm "$@"
}

#--- Enhanced Status (yadm status + n0dm info) ---------------------------------
n0dm_status() {
    # First, show native yadm status (passthrough behavior)
    echo -e "${BOLD}=== Yadm Repository Status ===${RESET}"
    yadm status "$@" 2>/dev/null || print_warn "Yadm not initialized"
    echo

    # Then, append n0dm-specific backup info
    echo -e "${BOLD}=== N0DM Backup Status ===${RESET}"
    local count=0
    if [[ -d "$N0DM_BACKUP_DIR" ]]; then
        count=$(find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
    fi
    echo "  Backups stored: $count / $MAX_BACKUPS"
    echo "  Retention: $BACKUP_RETENTION_DAYS days"
    echo "  Last backup epoch: $(get_last_backup_epoch)"
    echo "  Backup directory: $N0DM_BACKUP_DIR"
    echo

    echo -e "${BOLD}=== N0DM Info ===${RESET}"
    echo "  Version: $N0DM_VERSION"
    echo "  Script: $(realpath "$0")"

    # Check for remote
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    if [[ -d "$yadm_git_dir" ]]; then
        local remote_url
        remote_url=$(git --git-dir="$yadm_git_dir" remote get-url origin 2>/dev/null || echo "")
        if [[ -n "$remote_url" ]]; then
            echo -e "  ${GREEN}✓ Remote configured:${RESET} $remote_url"
        else
            echo -e "  ${YELLOW}⚠ No remote configured${RESET}"
            echo -e "     ${BLUE}→ Run:${RESET} n0dm connect <user/repo>"
        fi
    fi

    # Smart backup preview
    if needs_smart_backup 2>/dev/null; then
        echo -e "  ${YELLOW}⚠ Tracked files have changed since last backup${RESET}"
    else
        echo -e "  ${GREEN}✓ Tracked files unchanged (next sync will skip backup)${RESET}"
    fi
}

#--- Enhanced List (yadm list + optional backup summary) -----------------------
n0dm_list() {
    # Pass through to yadm's native list command
    yadm list "$@"
    
    # Optional: show brief backup summary after list (non-intrusive)
    if [[ -d "$N0DM_BACKUP_DIR" ]]; then
        local count; count=$(find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
        if [[ "$count" -gt 0 ]]; then
            echo
            print_notice "Tip: $count backup(s) available. Use 'n0dm backups' to list or 'n0dm restore <id>' to recover."
        fi
    fi
}

