#!/usr/bin/env bash
#===============================================================================
# N0DM - Enhanced Yadm Wrapper for Arch Linux
# Version: 2.0.7
# Combines Yadm's reliability with smart backups and safety features
#===============================================================================
set -euo pipefail

#--- Configuration -------------------------------------------------------------
readonly N0DM_VERSION="2.0.7"
readonly N0DM_UPDATE_URL="https://raw.githubusercontent.com/noeltz/n0dm/main/n0dm"
readonly N0DM_CHECKSUM_URL="https://raw.githubusercontent.com/noeltz/n0dm/main/n0dm.sha256"
readonly N0DM_DATA_DIR="${HOME}/.local/share/n0dm"
readonly N0DM_BACKUP_DIR="${N0DM_DATA_DIR}/backups"
readonly N0DM_CONFIG="${N0DM_DATA_DIR}/config"
readonly N0DM_STATE_FILE="${N0DM_DATA_DIR}/state"
MAX_BACKUPS="${N0DM_MAX_BACKUPS:-10}"
BACKUP_RETENTION_DAYS="${N0DM_BACKUP_RETENTION:-30}"

#--- Colors & Output -----------------------------------------------------------
readonly RESET='\033[0m' BOLD='\033[1m' RED='\033[31m' GREEN='\033[32m'
readonly YELLOW='\033[33m' BLUE='\033[34m' MAGENTA='\033[35m' CYAN='\033[36m'
readonly CHECK='✓' CROSS='✗' ARROW='➜' WARN='⚠' INFO='ℹ'

print_ok()    { echo -e "${GREEN}${CHECK}${RESET} $*"; }
print_err()   { echo -e "${RED}${CROSS}${RESET} $*" >&2; }
print_info()  { echo -e "${BLUE}${ARROW}${RESET} $*"; }
print_warn()  { echo -e "${YELLOW}${WARN}${RESET} $*"; }
print_notice(){ echo -e "${MAGENTA}${INFO}${RESET} $*"; }

send_notification() {
    local title="$1"
    local message="$2"
    local urgency="${3:-normal}"
    
    if command -v notify-send &>/dev/null; then
        notify-send -u "$urgency" "$title" "$message" 2>/dev/null || true
    fi
}

#--- Helpers -------------------------------------------------------------------
ensure_dirs() {
    mkdir -p "$N0DM_BACKUP_DIR" "$(dirname "$N0DM_CONFIG")" "$(dirname "$N0DM_STATE_FILE")"
}

load_config() {
    if [[ -f "$N0DM_CONFIG" ]]; then
        while IFS='=' read -r key value; do
            case "$key" in
                N0DM_MAX_BACKUPS)     MAX_BACKUPS=${value:-10} ;;
                N0DM_BACKUP_RETENTION) BACKUP_RETENTION_DAYS=${value:-30} ;;
            esac
        done < "$N0DM_CONFIG"
    fi
}

save_config() {
    cat > "$N0DM_CONFIG" <<EOF
# N0DM config (auto-generated - safe parsing, no code execution)
N0DM_MAX_BACKUPS=${MAX_BACKUPS}
N0DM_BACKUP_RETENTION=${BACKUP_RETENTION_DAYS}
EOF
}

timestamp() { date +"%Y%m%d_%H%M%S"; }
epoch_time() { date +%s; }

check_yadm() {
    if ! command -v yadm &> /dev/null; then
        print_err "Yadm not found. Install with: sudo pacman -S yadm"
        exit 1
    fi
}

_YADM_GIT_DIR_CACHED=""

get_yadm_git_dir() {
    if [[ -n "$_YADM_GIT_DIR_CACHED" ]]; then
        echo "$_YADM_GIT_DIR_CACHED"
        return
    fi
    
    local yadm_dir
    if command -v yadm &>/dev/null; then
        yadm_dir=$(yadm rev-parse --git-dir 2>/dev/null)
        if [[ -n "$yadm_dir" && -d "$yadm_dir" ]]; then
            _YADM_GIT_DIR_CACHED="$yadm_dir"
            echo "$yadm_dir"
            return
        fi
    fi
    
    yadm_dir="${HOME}/.local/share/yadm/repo.git"
    _YADM_GIT_DIR_CACHED="$yadm_dir"
    echo "$yadm_dir"
}

#--- State Management for Smart Backups ----------------------------------------
# Read a value from the state file (robust key=value parsing)
# Usage: state_get "key" "default_value"
state_get() {
    local key="$1"
    local default="${2:-}"
    if [[ -f "$N0DM_STATE_FILE" ]]; then
        local value
        value=$(grep "^${key}=" "$N0DM_STATE_FILE" 2>/dev/null | cut -d= -f2-)
        if [[ -n "$value" ]]; then
            echo "$value"
            return 0
        fi
    fi
    echo "$default"
}

# Write a value to the state file (updates or adds)
# Usage: state_set "key" "value"
state_set() {
    local key="$1"
    local value="$2"
    mkdir -p "$(dirname "$N0DM_STATE_FILE")"
    
    if grep -q "^${key}=" "$N0DM_STATE_FILE" 2>/dev/null; then
        # Update existing key (use temp file for BSD compatibility)
        local tmp_file; tmp_file=$(mktemp)
        sed "s|^${key}=.*|${key}=${value}|" "$N0DM_STATE_FILE" > "$tmp_file"
        mv "$tmp_file" "$N0DM_STATE_FILE"
    else
        # Add new key
        echo "${key}=${value}" >> "$N0DM_STATE_FILE"
    fi
}

get_last_backup_epoch() {
    state_get "last_backup_epoch" "0"
}

set_last_backup_epoch() {
    local epoch="$1"
    state_set "last_backup_epoch" "$epoch"
}

#--- Smart Backup Detection ----------------------------------------------------
# Returns 0 (true) if tracked files have changed since last backup
needs_smart_backup() {
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    local last_backup_epoch; last_backup_epoch=$(get_last_backup_epoch)
    
    # If no previous backup, always backup on first sync
    if [[ "$last_backup_epoch" -eq 0 ]]; then
        return 0
    fi
    
    # Check if there are any staged changes (adds, deletes, renames)
    local staged_count
    staged_count=$(git --git-dir="$yadm_git_dir" diff --cached --name-only 2>/dev/null | wc -l)
    if [[ "$staged_count" -gt 0 ]]; then
        return 0  # Staged changes exist - need backup
    fi
    
    # Check if any tracked file was modified after last backup
    cd "$HOME" || return 1
    while IFS= read -r -d '' file; do
        [[ -z "$file" ]] && continue
        local full_path="${HOME}/${file}"
        # Skip if file doesn't exist in home (might be repo-only)
        [[ ! -e "$full_path" ]] && continue
        # Get file modification time
        local file_mtime; file_mtime=$(stat -c %Y "$full_path" 2>/dev/null || echo "0")
        if [[ "$file_mtime" -gt "$last_backup_epoch" ]]; then
            return 0  # Change detected
        fi
    done < <(git --git-dir="$yadm_git_dir" --work-tree="$HOME" ls-files -z 2>/dev/null)
    
    return 1  # No changes detected
}

#--- Backup System -------------------------------------------------------------
create_backup() {
    local label="${1:-manual}"
    local ts; ts=$(timestamp)
    local epoch; epoch=$(epoch_time)
    local backup_dir="${N0DM_BACKUP_DIR}/${ts}_${label}"
    
    print_info "Creating backup: ${backup_dir#$HOME/}"
    mkdir -p "$backup_dir"
    
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    
    if [[ ! -d "$yadm_git_dir" ]]; then
        print_err "Yadm repository not found. Run 'n0dm init' first."
        return 1
    fi
    
    # Use git archive to export tracked files cleanly
    # Use --reflink=auto for Btrfs/XFS (instant copy, zero extra space)
    cd "$HOME"
    git --git-dir="$yadm_git_dir" --work-tree="$HOME" ls-files -z | \
        while IFS= read -r -d '' file; do
            # Skip if file doesn't exist (deleted or renamed)
            [[ ! -e "$file" ]] && continue
            mkdir -p "$backup_dir/$(dirname "$file")"
            cp -a --reflink=auto "$file" "$backup_dir/$file"
        done
    
    # Store metadata
    cat > "${backup_dir}/.n0dm-meta" <<EOF
timestamp=$ts
epoch=$epoch
label=$label
yadm_branch=$(git --git-dir="$yadm_git_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
n0dm_version=${N0DM_VERSION}
EOF
    
    # Update state file with backup epoch
    set_last_backup_epoch "$epoch"
    
    # Cleanup old backups (smart retention)
    cleanup_backups
    
    print_ok "Backup created: $(basename "$backup_dir")"
    echo "$backup_dir"
}

list_backups() {
    if [[ ! -d "$N0DM_BACKUP_DIR" ]] || [[ -z "$(ls -A "$N0DM_BACKUP_DIR" 2>/dev/null)" ]]; then
        print_warn "No backups found"
        return 1
    fi
    
    echo -e "\n${BOLD}Available Backups:${RESET}"
    printf "%-30s %-15s %-10s %s\n" "BACKUP ID" "DATE" "EPOCH" "LABEL"
    printf "%-30s %-15s %-10s %s\n" "$(printf '%.0s-' {1..30})" "$(printf '%.0s-' {1..15})" "$(printf '%.0s-' {1..10})" "$(printf '%.0s-' {1..10})"
    
    find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort -r | while read -r backup; do
        local ts="${backup:0:15}"
        local label="${backup:16}"
        local date_fmt="${ts:0:4}-${ts:4:2}-${ts:6:2} ${ts:9:2}:${ts:11:2}"
        # Extract epoch from metadata if available
        local epoch="N/A"
        if [[ -f "${N0DM_BACKUP_DIR}/${backup}/.n0dm-meta" ]]; then
            epoch=$(grep "^epoch=" "${N0DM_BACKUP_DIR}/${backup}/.n0dm-meta" 2>/dev/null | cut -d= -f2 || echo "N/A")
        fi
        printf "%-30s %-15s %-10s %s\n" "$backup" "$date_fmt" "$epoch" "$label"
    done
    echo
}

restore_backup() {
    local backup_id="$1"
    local backup_dir="${N0DM_BACKUP_DIR}/${backup_id}"
    
    if [[ ! -d "$backup_dir" ]]; then
        print_err "Backup not found: $backup_id"
        list_backups
        return 1
    fi
    
    print_warn "This will overwrite tracked files in your home directory"
    if [[ "${N0DM_YES:-false}" != "true" ]]; then
        read -p "Proceed with restore? [y/N] " -n 1 -r
        echo
        [[ $REPLY =~ ^[Yy]$ ]] || { print_info "Restore cancelled"; return 0; }
    fi
    
    # Create safety backup first (always, regardless of smart logic)
    print_info "Creating safety backup before restore..."
    create_backup "pre-restore" >/dev/null
    
    # Restore files (use --reflink=auto for Btrfs/XFS)
    print_info "Restoring from: $backup_id"
    cd "$backup_dir"
    find . -type f ! -name '.n0dm-meta' -exec sh -c '
        rel="${1#./}"
        [[ -n "$rel" ]] && { mkdir -p "$HOME/$(dirname "$rel")" && cp -a --reflink=auto "$1" "$HOME/$rel"; }
    ' _ {} \;
    
    print_ok "Restore completed!"
    print_info "Run 'n0dm status' or 'yadm status' to verify"
}

cleanup_backups() {
    [[ ! -d "$N0DM_BACKUP_DIR" ]] && return 0

    local now; now=$(epoch_time)
    local retention_secs=$((BACKUP_RETENTION_DAYS * 86400))
    local count=0 removed=0

    # Sort by name (timestamp) descending, keep newest MAX_BACKUPS
    # Use process substitution to avoid subshell (variables persist)
    while read -r backup; do
        count=$((count + 1))
        local backup_path="${N0DM_BACKUP_DIR}/${backup}"
        local backup_time; backup_time=$(stat -c %Y "$backup_path" 2>/dev/null || echo 0)
        local age=$((now - backup_time))

        # Remove if too old OR beyond max count
        if ((age > retention_secs)) || ((count > MAX_BACKUPS)); then
            rm -rf "$backup_path"
            print_info "Removed old backup: $backup"
            removed=$((removed + 1))
        fi
    done < <(find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort -r)

    if [[ $removed -gt 0 ]]; then
        print_ok "Cleanup: removed $removed backup(s)"
    fi
    return 0
}

#--- Auto-Commit Message Generator ---------------------------------------------
generate_commit_message() {
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    
    # Get summary of changes
    local stats
    stats=$(cd "$HOME" && git --git-dir="$yadm_git_dir" --work-tree="$HOME" diff --stat --shortstat 2>/dev/null || echo "")
    
    # Get list of changed files (max 5, then show "+N more")
    local files
    files=$(cd "$HOME" && git --git-dir="$yadm_git_dir" --work-tree="$HOME" diff --name-only --diff-filter=ACMRT 2>/dev/null | head -5 | xargs -0 basename -a 2>/dev/null | tr '\n' ',' | sed 's/,$//')
    
    if [[ -z "$stats" && -z "$files" ]]; then
        echo "Sync"
        return
    fi
    
    # Parse the shortstat to get counts
    local added=0 removed=0 modified=0
    if [[ "$stats" =~ ([0-9]+)\ addition ]]; then
        added="${BASH_REMATCH[1]}"
    fi
    if [[ "$stats" =~ ([0-9]+)\ deletion ]]; then
        removed="${BASH_REMATCH[1]}"
    fi
    if [[ "$stats" =~ ([0-9]+)\ file? ]]; then
        modified="${BASH_REMATCH[1]}"
    fi
    
    # Build message
    local msg=""
    if [[ -n "$files" ]]; then
        msg="$files"
    fi
    
    # Add counts if we have them
    if [[ -n "$added" || -n "$removed" ]]; then
        local counts=()
        [[ "$added" -gt 0 ]] && counts+=("+$added")
        [[ "$removed" -gt 0 ]] && counts+=("-$removed")
        if [[ ${#counts[@]} -gt 0 ]]; then
            [[ -n "$msg" ]] && msg+=" "
            msg+="[${counts[*]}]"
        fi
    fi
    
    if [[ -n "$msg" ]]; then
        echo "$msg"
    else
        echo "Sync"
    fi
}

#--- Safe Sync Wrapper with Smart Backup ---------------------------------------
n0dm_safe_sync() {
    local message="${1:-}"
    local no_backup="${2:-false}"
    local dry_run="${3:-false}"
    local force="${4:-false}"
    local safe_mode="${5:-false}"
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    local sync_success=false
    
    # Auto-generate message if not provided
    if [[ -z "$message" ]]; then
        message=$(generate_commit_message)
    fi

    # Check yadm is initialized
    if ! yadm status &>/dev/null; then
        print_err "Yadm not initialized. Run 'n0dm init' first."
        return 1
    fi

    # Check for remote
    if ! yadm remote get-url origin &>/dev/null; then
        print_err "No remote configured. Run 'n0dm connect' first."
        return 1
    fi

    # Smart backup: only create if tracked files changed AND backup not disabled
    if [[ "$no_backup" != "true" && "$dry_run" != "true" ]]; then
        if needs_smart_backup; then
            print_info "Changes detected in tracked files, creating pre-sync backup..."
            create_backup "pre-sync" >/dev/null
        else
            print_info "No changes in tracked files, skipping backup"
        fi
    fi

    # Dry run mode
    if [[ "$dry_run" == "true" ]]; then
        print_info "=== DRY RUN ==="
        yadm status --short
        print_info "=== END DRY RUN ==="
        return 0
    fi

    # Commit local changes (only tracked files, respects .gitignore)
    # Check for staged changes first (from n0dm track), then modified tracked files
    print_info "Committing changes..."
    if git --git-dir="$yadm_git_dir" diff --cached --quiet 2>/dev/null; then
        # No staged changes, try -a flag for modified tracked files
        if yadm commit -am "$message" 2>/dev/null; then
            print_ok "Changes committed"
        else
            print_warn "Nothing to commit"
        fi
    else
        # Has staged changes (e.g., from n0dm track), commit them
        if yadm commit -m "$message" 2>/dev/null; then
            print_ok "Changes committed"
        else
            print_warn "Nothing to commit"
        fi
    fi

    # Check if we have any commits
    local commit_count
    commit_count=$(git --git-dir="$yadm_git_dir" rev-list --count HEAD 2>/dev/null || echo "0")

    if [[ "$commit_count" -eq 0 ]]; then
        print_err "No commits yet. Add files with 'n0dm add <file>' and commit first."
        return 1
    fi

    # Pull with conflict detection (skip on first push)
    local has_upstream
    has_upstream=$(git --git-dir="$yadm_git_dir" rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")

    if [[ -n "$has_upstream" ]]; then
        # Check for divergent branches BEFORE pulling
        local local_head remote_head divergent=false
        local_head=$(git --git-dir="$yadm_git_dir" rev-parse HEAD 2>/dev/null || echo "")
        remote_head=$(git --git-dir="$yadm_git_dir" rev-parse @{u} 2>/dev/null || echo "")
        
        if [[ -n "$local_head" && -n "$remote_head" ]]; then
            local merge_base
            merge_base=$(git --git-dir="$yadm_git_dir" merge-base HEAD @{u} 2>/dev/null || echo "")
            if [[ -n "$merge_base" && "$merge_base" != "$local_head" && "$merge_base" != "$remote_head" ]]; then
                divergent=true
            fi
        fi
        
        if [[ "$divergent" == "true" ]]; then
            print_warn "Branches have diverged: local and remote have different commit histories"
            print_info "Local has $(git --git-dir="$yadm_git_dir" rev-list --count HEAD ^@{u} 2>/dev/null || echo "?") commit(s), remote has $(git --git-dir="$yadm_git_dir" rev-list --count @{u} ^HEAD 2>/dev/null || echo "?")"
            
            # In auto mode, notify and exit
            if [[ "$yes_mode" == "true" || "$safe_mode" == "true" ]]; then
                print_err "Cannot auto-sync: branches have diverged"
                print_info "Run 'n0dm sync' interactively to resolve, or choose manually:"
                echo "  n0dm pull --rebase    # Replay local on top of remote (cleaner)"
                echo "  n0dm pull --no-rebase # Merge both histories"
                send_notification "n0dm Sync Failed" "Branches have diverged - run 'n0dm sync' manually to resolve" "critical"
                return 1
            fi
            
            # Interactive mode: let user choose
            echo
            local choice=""
            while [[ ! "$choice" =~ ^[RrMmQq]$ ]]; do
                echo -n "Choose: (R)ebase local on remote, (M)erge remote, (Q)uit: "
                read -n 1 -r choice
                echo
                [[ -z "$choice" ]] && choice="Q"
            done
            
            case "$choice" in
                R|r)
                    print_info "Rebasing local commits on top of remote..."
                    local rebase_output rebase_status=0
                    if ! rebase_output=$(yadm pull --rebase 2>&1); then
                        rebase_status=$?
                        # Check if failed due to untracked files
                        if echo "$rebase_output" | grep -qi "untracked working tree files"; then
                            print_warn "Rebase failed: untracked files would be overwritten"
                            echo "$rebase_output" | grep -E "^[[:space:]]*\." | head -10 | while read -r f; do
                                print_info "  $f"
                            done
                            echo
                            echo "Options:"
                            echo "  (M)erge remote into local"
                            echo "  (B)ackup untracked files, pull, then restore from backup"
                            echo "  (Q)uit"
                            echo
                            local sub_choice=""
                            while [[ ! "$sub_choice" =~ ^[MmBbQq]$ ]]; do
                                echo -n "Choose: "
                                read -n 1 -r sub_choice
                                echo
                                [[ -z "$sub_choice" ]] && sub_choice="Q"
                            done
                            
                            case "$sub_choice" in
                                M|m)
                                    print_info "Merging remote into local..."
                                    if ! yadm pull --no-rebase 2>&1; then
                                        print_err "Merge failed"
                                        return 1
                                    fi
                                    ;;
                                B|b)
                                    # Extract list of untracked files to backup
                                    local untracked_files=()
                                    while IFS= read -r f; do
                                        [[ -z "$f" ]] && continue
                                        f=$(echo "$f" | xargs)  # trim whitespace
                                        [[ -n "$f" ]] && untracked_files+=("$f")
                                    done < <(echo "$rebase_output" | grep -E "^[[:space:]]*\." | head -20)
                                    
                                    if [[ ${#untracked_files[@]} -gt 0 ]]; then
                                        print_info "Creating backup of untracked files..."
                                        local backup_label="pre-sync-untracked-$(timestamp)"
                                        local backup_dir; backup_dir=$(create_backup "$backup_label" 2>/dev/null || echo "")
                                        
                                        # Remove untracked files so rebase can proceed
                                        print_info "Removing untracked files to allow rebase..."
                                        for f in "${untracked_files[@]}"; do
                                            [[ -f "$HOME/$f" ]] && rm -f "$HOME/$f" 2>/dev/null
                                        done
                                        
                                        print_info "Retrying rebase..."
                                        if ! yadm pull --rebase 2>&1; then
                                            print_err "Rebase failed even after removing files"
                                            print_info "Restoring backup manually with: n0dm restore $backup_label"
                                            return 1
                                        fi
                                        
                                        print_ok "Rebase succeeded!"
                                        print_info "Untracked files backed up to: $backup_label"
                                        print_info "To restore: n0dm restore $backup_label"
                                    else
                                        print_err "Could not identify untracked files to backup"
                                        return 1
                                    fi
                                    ;;
                                Q|q)
                                    print_info "Sync cancelled"
                                    return 0
                                    ;;
                            esac
                        else
                            print_err "Rebase failed: $rebase_output"
                            return 1
                        fi
                    fi
                    ;;
                M|m)
                    print_info "Merging remote into local..."
                    if ! yadm pull --no-rebase 2>&1; then
                        print_err "Merge failed"
                        return 1
                    fi
                    ;;
                Q|q)
                    print_info "Sync cancelled. Resolve manually with 'n0dm pull --rebase' or 'n0dm pull --no-rebase'"
                    return 0
                    ;;
            esac
        else
            print_info "Pulling remote changes..."
            if ! yadm pull --ff-only 2>/dev/null; then
                print_warn "Fast-forward pull failed, attempting regular merge..."
                # Try a regular pull that can create merge commits
                local pull_output
                if ! pull_output=$(yadm pull 2>&1); then
                    # Check if it's a conflict (unmerged files)
                    if git --git-dir="$yadm_git_dir" diff --name-only --diff-filter=U 2>/dev/null | grep -q .; then
                        print_err "Merge conflicts detected!"
                        print_info "Resolve with: n0dm conflicts --fix"
                        print_info "Or use: n0dm mergetool for visual resolution"
                        if [[ "$safe_mode" == "true" || "$yes_mode" == "true" ]]; then
                            send_notification "n0dm Conflict Detected" "Merge conflicts need resolution" "critical"
                        fi
                        return 1
                    fi
                    # If pull failed but no conflicts, something else went wrong
                    print_err "Pull failed: $pull_output"
                    return 1
                fi
            fi
        fi
    fi

    # Push
    print_info "Pushing to remote..."
    if [[ -z "$has_upstream" ]]; then
        # First push - set upstream
        local push_output push_status=0
        local force_flag=""
        [[ "$force" == "true" ]] && force_flag="--force"
        push_output=$(yadm push $force_flag --set-upstream origin "$(yadm branch --show-current)" 2>&1) || push_status=$?
        if [[ $push_status -ne 0 ]]; then
            # Check if it's a "repository not found" error
            if echo "$push_output" | grep -qi "not found"; then
                print_err "Push failed. The remote repository does not exist yet."
                local remote_url
                remote_url=$(git --git-dir="$yadm_git_dir" remote get-url origin 2>/dev/null)
                local repo_name
                repo_name=$(echo "$remote_url" | sed 's|.*/\([^/]*\)\.git$|\1|' | sed 's|^git@github\.com:||')
                
                # Offer to create repo if gh is available
                if command -v gh &>/dev/null; then
                    echo
                    print_info "I can create this repository for you automatically."
                    if [[ "${N0DM_YES:-false}" == "true" ]]; then
                        auto_confirm="y"
                    else
                        read -p "Create GitHub repo and push? [Y/n] " -n 1 -r auto_confirm
                        echo
                    fi
                    
                    if [[ $auto_confirm =~ ^[Yy]$ || "$auto_confirm" == "" ]]; then
                        print_info "Creating repository on GitHub..."
                        if gh repo create "$repo_name" --public --source=. --push 2>&1; then
                            print_ok "Repository created and pushed successfully!"
                        else
                            print_err "Failed to create repository. It may already exist on GitHub."
                            print_info "Try: gh repo create $repo_name --public --push"
                        fi
                    else
                        echo
                        print_info "Create it manually:"
                        echo "  gh repo create $repo_name --public --push"
                        echo "Or visit: $remote_url"
                    fi
                else
                    print_info "Create it on GitHub:"
                    echo "  gh repo create $repo_name --public --push"
                    echo "Or visit: $remote_url"
                fi
            elif echo "$push_output" | grep -qi "rejected"; then
                print_warn "Remote has different history (e.g., README from GitHub)."
                print_info "Options:"
                echo "  1. Pull and merge: n0dm pull --rebase && n0dm sync"
                echo "  2. Overwrite remote: n0dm sync --force"
            else
                print_err "Push failed:"
                echo "$push_output"
            fi
            if [[ "$safe_mode" == "true" || "$yes_mode" == "true" ]]; then
                send_notification "n0dm Sync Failed" "Push failed - check manually" "critical"
            fi
            return 1
        fi
    else
        local push_status=0
        local push_output
        if ! push_output=$(yadm push 2>&1); then
            push_status=$?
        fi
        if [[ $push_status -ne 0 ]]; then
            print_err "Push failed. Your changes are committed locally."
            echo "$push_output"
            print_info "If remote has different history, try:"
            echo "  1. n0dm pull --rebase && n0dm sync"
            echo "  2. n0dm sync --force (overwrites remote)"
            if [[ "$safe_mode" == "true" || "$yes_mode" == "true" ]]; then
                send_notification "n0dm Sync Failed" "Push rejected - check manually" "critical"
            fi
            return 1
        fi
    fi

    print_ok "Sync complete!"
    sync_success=true

    # Post-sync cleanup (always run to maintain retention)
    cleanup_backups
    
    # Send success notification for automated runs
    if [[ "$yes_mode" == "true" ]]; then
        send_notification "n0dm Sync Complete" "Dotfiles synced successfully" "normal"
    fi
    
    return 0
}

#--- Conflict Helper -----------------------------------------------------------
n0dm_check_conflicts() {
    local fix_mode="${1:-}"
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)

    local conflicts
    conflicts=$(git --git-dir="$yadm_git_dir" diff --name-only --diff-filter=U 2>/dev/null)
    
    if [[ -n "$conflicts" ]]; then
        print_err "Unresolved merge conflicts:"
        echo "$conflicts"
        echo
        
        # If --fix flag provided, launch resolver
        if [[ "$fix_mode" == "--fix" ]]; then
            n0dm_resolve_conflicts
            return $?
        fi
        
        print_info "Resolve with: n0dm conflicts --fix"
        print_info "Or use visual editor: n0dm mergetool"
        return 1
    fi
    return 0
}

#--- Conflict Resolver ----------------------------------------------------------
n0dm_resolve_conflicts() {
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    
    # Check for conflicts
    local conflicts
    conflicts=$(git --git-dir="$yadm_git_dir" diff --name-only --diff-filter=U 2>/dev/null)
    
    if [[ -z "$conflicts" ]]; then
        print_ok "No merge conflicts to resolve"
        return 0
    fi
    
    echo -e "${BOLD}=== Resolving Merge Conflicts ===${RESET}"
    echo
    
    local conflict_count=0
    local resolved_count=0
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        conflict_count=$((conflict_count + 1))
        
        local full_path="${HOME}/${file}"
        
        echo -e "${RED}=== Conflict #$conflict_count: $file ===${RESET}"
        
        # Show diff
        echo -e "${YELLOW}--- Local changes (yours) ---${RESET}"
        git --git-dir="$yadm_git_dir" show ":1:$file" 2>/dev/null | head -20 || echo "(empty)"
        echo
        echo -e "${CYAN}--- Remote changes (GitHub) ---${RESET}"
        git --git-dir="$yadm_git_dir" show ":2:$file" 2>/dev/null | head -20 || echo "(empty)"
        echo
        
        # Prompt user
        local choice=""
        while [[ ! "$choice" =~ ^[LlRrMmSsQq]$ ]]; do
            echo -n "Choose: (L)ocal, (R)emote, (M)erge, (S)kip, (Q)uit: "
            read -n 1 -r choice
            echo
            [[ -z "$choice" ]] && choice="Q"  # Default to Quit
        done
        
        case "$choice" in
            L|l)
                git --git-dir="$yadm_git_dir" show ":1:$file" > "$full_path" 2>/dev/null || true
                yadm add "$file" 2>/dev/null || true
                print_ok "Kept local version"
                resolved_count=$((resolved_count + 1))
                ;;
            R|r)
                git --git-dir="$yadm_git_dir" show ":2:$file" > "$full_path" 2>/dev/null || true
                yadm add "$file" 2>/dev/null || true
                print_ok "Kept remote version"
                resolved_count=$((resolved_count + 1))
                ;;
            M|m)
                if command -v meld &>/dev/null; then
                    meld "$full_path" &>/dev/null &
                    print_info "Opened meld for $file"
                    print_info "After saving in meld, run: n0dm add $file"
                elif [[ -n "${EDITOR:-}" ]]; then
                    "$EDITOR" "$full_path"
                    print_info "After saving, run: n0dm add $file"
                else
                    print_warn "No merge tool configured."
                    print_info "Install meld or set EDITOR variable, then run: n0dm mergetool"
                fi
                ;;
            S|s)
                print_warn "Skipped - will need manual resolution"
                ;;
            Q|q)
                echo
                print_info "Conflict resolution aborted"
                print_info "Resolved: $resolved_count / $conflict_count file(s)"
                print_info "Run 'n0dm conflicts' to check status later"
                return 1
                ;;
        esac
        echo
    done <<< "$conflict_count"
    
    print_ok "Conflict resolution complete: $resolved_count / $conflict_count resolved"
    print_info "Run 'n0dm sync' to complete the merge"
    return 0
}

#--- Sync Health Check ---------------------------------------------------------
n0dm_health() {
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    local issues=0
    local -A issue_types
    
    echo -e "${BOLD}=== n0dm Health Check ===${RESET}"
    echo
    
    # Check yadm is initialized
    print_info "Checking yadm repository..."
    if yadm status &>/dev/null; then
        print_ok "Yadm repository initialized"
    else
        print_err "Yadm not initialized"
        issues=$((issues + 1))
        issue_types[no_yadm]=1
    fi
    
    # Check remote configured
    print_info "Checking remote configuration..."
    if yadm remote get-url origin &>/dev/null; then
        local remote_url
        remote_url=$(yadm remote get-url origin)
        print_ok "Remote configured: $remote_url"

        # Check if can reach remote
        print_info "Checking remote connectivity..."
        local ls_output
        if ls_output=$(git ls-remote --exit-code origin 2>&1); then
            print_ok "Remote is reachable"
        else
            # Check if it's an auth issue
            if echo "$ls_output" | grep -qiE "authentication|not found|could not read|denied"; then
                print_err "Authentication failed"
                issues=$((issues + 1))
                issue_types[auth_failed]=1
                
                # Check gh auth status
                if command -v gh &>/dev/null; then
                    if ! gh auth status &>/dev/null; then
                        print_info "GitHub CLI is not authenticated"
                        print_info "Run: gh auth login"
                    fi
                fi
            else
                print_warn "Remote may not be reachable"
            fi
        fi
    else
        print_err "No remote configured"
        issues=$((issues + 1))
        issue_types[no_remote]=1
    fi
    
    # Check for conflicts
    print_info "Checking for unresolved conflicts..."
    if n0dm_check_conflicts &>/dev/null; then
        print_ok "No merge conflicts"
    else
        print_err "Unresolved merge conflicts detected"
        issues=$((issues + 1))
        issue_types[conflicts]=1
    fi
    
    # Check backup status
    print_info "Checking backup status..."
    local backup_count=0
    if [[ -d "$N0DM_BACKUP_DIR" ]]; then
        backup_count=$(find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
    fi
    echo "  Backups stored: $backup_count / $MAX_BACKUPS"
    echo "  Retention: $BACKUP_RETENTION_DAYS days"
    
    if [[ $backup_count -eq 0 ]]; then
        print_warn "No backups available"
        issue_types[no_backups]=1
    else
        print_ok "Backups available"
    fi
    
    # Check last sync
    print_info "Checking sync status..."
    local has_upstream
    has_upstream=$(git --git-dir="$yadm_git_dir" rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")
    if [[ -n "$has_upstream" ]]; then
        local local_rev remote_rev
        local_rev=$(git --git-dir="$yadm_git_dir" rev-parse HEAD)
        remote_rev=$(git --git-dir="$yadm_git_dir" rev-parse @{u})
        if [[ "$local_rev" == "$remote_rev" ]]; then
            print_ok "Local and remote are in sync"
        else
            print_warn "Local and remote differ - run 'n0dm sync'"
            issue_types[out_of_sync]=1
        fi
    else
        print_warn "No upstream branch configured"
        if yadm remote get-url origin &>/dev/null; then
            issues=$((issues + 1))
            issue_types[no_upstream]=1
        fi
    fi
    
    # Check systemd timer if enabled
    if command -v systemctl &>/dev/null; then
        print_info "Checking auto-sync timer..."
        if systemctl --user is-enabled n0dm-sync.timer &>/dev/null; then
            print_ok "Auto-sync timer is enabled"
            systemctl --user list-timers --no-pager | grep n0dm-sync || true
        else
            print_info "Auto-sync timer is not enabled"
            issue_types[no_timer]=1
        fi
    fi
    
    echo
    if [[ $issues -eq 0 && ${#issue_types[@]} -eq 0 ]]; then
        print_ok "Health check passed - no issues found"
        
        # Offer to run guided onboarding/setup
        if [[ "${N0DM_YES:-false}" != "true" ]]; then
            echo
            print_notice "Everything looks good! Would you like to set up automation?"
            read -p "Setup auto-sync and hooks? [y/N] " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                n0dm_guided_setup
            fi
        fi
        return 0
    fi
    
    print_err "Health check found issues"
    
    # Run healing wizard automatically
    n0dm_heal "${!issue_types[@]}"
    return $?
}

#--- Healing Wizard --------------------------------------------------------------
n0dm_heal() {
    local issue_list=("$@")
    local -A issue_actions
    
    echo
    echo -e "${BOLD}=== n0dm Healing Wizard ===${RESET}"
    echo
    
    # Map issues to actions
    local need_init=false need_connect=false need_push=false
    local need_conflicts=false need_backup=false need_sync=false need_timer=false
    local need_auth=false

    for issue in "${issue_list[@]}"; do
        case "$issue" in
            no_yadm) need_init=true ;;
            no_remote) need_connect=true ;;
            no_upstream) need_push=true ;;
            conflicts) need_conflicts=true ;;
            no_backups) need_backup=true ;;
            out_of_sync) need_sync=true ;;
            no_timer) need_timer=true ;;
            auth_failed) need_auth=true ;;
        esac
    done

    # Show menu and let user choose
    echo "Select what to fix:"
    local options=()
    local option_count=0

    [[ "$need_init" == "true" ]] && { option_count=$((option_count + 1)); options+=("init"); echo "  $option_count) Initialize yadm repository"; }
    [[ "$need_connect" == "true" ]] && { option_count=$((option_count + 1)); options+=("connect"); echo "  $option_count) Connect to GitHub repository"; }
    [[ "$need_push" == "true" ]] && { option_count=$((option_count + 1)); options+=("push"); echo "  $option_count) Push to remote and setup tracking"; }
    [[ "$need_conflicts" == "true" ]] && { option_count=$((option_count + 1)); options+=("conflicts"); echo "  $option_count) Resolve merge conflicts"; }
    [[ "$need_backup" == "true" ]] && { option_count=$((option_count + 1)); options+=("backup"); echo "  $option_count) Create first backup"; }
    [[ "$need_sync" == "true" ]] && { option_count=$((option_count + 1)); options+=("sync"); echo "  $option_count) Sync with remote"; }
    [[ "$need_timer" == "true" ]] && { option_count=$((option_count + 1)); options+=("timer"); echo "  $option_count) Enable auto-sync timer"; }
    [[ "$need_auth" == "true" ]] && { option_count=$((option_count + 1)); options+=("auth"); echo "  $option_count) Re-authenticate with GitHub"; }
    
    option_count=$((option_count + 1)); options+=("all"); echo "  $option_count) Fix all issues"
    option_count=$((option_count + 1)); options+=("skip"); echo "  $option_count) Skip"
    
    echo
    read -p "Choose: " -r choice
    
    local -a choices
    if [[ "$choice" =~ ^[0-9]+$ ]]; then
        local idx=1
        for opt in "${options[@]}"; do
            if [[ $idx -eq $choice ]]; then
                choices=("$opt")
                break
            fi
            idx=$((idx + 1))
        done
    elif [[ "$choice" == "all" ]]; then
        choices=("${options[@]}")
    fi
    
    # Execute chosen fixes
    for cmd in "${choices[@]}"; do
        case "$cmd" in
            init)
                echo
                print_info "Running init..."
                n0dm_init
                ;;
            connect)
                echo
                print_info "Running connect..."
                n0dm_connect
                ;;
            push)
                echo
                print_info "Pushing to remote..."
                yadm push -u origin main 2>&1 || yadm push -u origin master 2>&1 || print_warn "Push failed"
                ;;
            conflicts)
                echo
                print_info "Starting conflict resolver..."
                n0dm_resolve_conflicts || true
                ;;
            backup)
                echo
                print_info "Creating backup..."
                create_backup "manual"
                ;;
            sync)
                echo
                print_info "Syncing..."
                n0dm_safe_sync "Heal sync" "false" "false" "false"
                ;;
            timer)
                echo
                print_info "Setting up auto-sync..."
                n0dm_schedule "daily"
                ;;
            auth)
                echo
                print_info "Authenticating with GitHub..."
                if command -v gh &>/dev/null; then
                    if gh auth login -h github.com -p https 2>&1; then
                        print_ok "GitHub authentication successful"
                    else
                        print_err "Authentication failed"
                        print_info "Try: gh auth login"
                    fi
                else
                    print_err "GitHub CLI (gh) not installed"
                    print_info "Install: sudo pacman -S github-cli"
                fi
                ;;
            skip)
                print_info "Skipping..."
                return 0
                ;;
        esac
    done
    
    echo
    print_ok "Healing complete!"
    print_info "Run 'n0dm health' to verify"
    return 0
}

#--- Guided Setup ---------------------------------------------------------------
n0dm_guided_setup() {
    echo
    echo -e "${BOLD}=== n0dm Guided Setup ===${RESET}"
    echo
    
    # Step 1: Track files
    print_info "Step 1: Track your dotfiles"
    echo "Files in your home directory that could be tracked:"
    echo "  - .bashrc, .zshrc (shell config)"
    echo "  - .config/nvim, .config/kitty (app config)"
    echo "  - .gitconfig, .tmux.conf"
    echo
    read -p "Enter files to track (space-separated), or press Enter to skip: " -r tracked_files
    if [[ -n "$tracked_files" ]]; then
        for file in $tracked_files; do
            n0dm_track "$file" 2>/dev/null || true
        done
        print_ok "Files tracked"
    fi
    
    # Step 2: First commit
    if [[ -n "$tracked_files" ]]; then
        echo
        print_info "Step 2: Create first commit"
        read -p "Enter commit message: " -r commit_msg
        [[ -z "$commit_msg" ]] && commit_msg="Initial dotfiles"
        yadm commit -m "$commit_msg" 2>/dev/null && print_ok "Commit created" || print_warn "Nothing to commit"
    fi
    
    # Step 3: Sync to remote
    if yadm remote get-url origin &>/dev/null; then
        echo
        print_info "Step 3: Sync to GitHub"
        read -p "Push to remote now? [Y/n] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ || "$REPLY" == "" ]]; then
            n0dm_safe_sync "Initial sync" "false" "false" "false"
        fi
    fi
    
    # Step 4: Auto-sync timer
    echo
    print_info "Step 4: Set up automation"
    echo "  (1) Enable hourly auto-sync"
    echo "  (2) Enable daily auto-sync"
    echo "  (3) Install pacman hook"
    echo "  (4) All of the above"
    echo "  (5) Skip"
    echo
    read -p "Choose: " -n 1 -r
    echo
    
    case "$REPLY" in
        1) n0dm_schedule hourly ;;
        2) n0dm_schedule daily ;;
        3) 
            if command -v sudo &>/dev/null; then
                sudo -v && n0dm_hook install
            else
                print_warn "sudo not available, skipping hook install"
            fi
            ;;
        4)
            n0dm_schedule daily
            if command -v sudo &>/dev/null; then
                sudo -v && n0dm_hook install
            fi
            ;;
        *) print_info "Skipped" ;;
    esac
    
    echo
    print_ok "Guided setup complete!"
    print_info "Run 'n0dm status' to see your dotfiles status"
}

#--- Connect to Remote ---------------------------------------------------------
n0dm_connect() {
    local repo="${1:-}"
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)

    if [[ ! -d "$yadm_git_dir" ]]; then
        print_err "Yadm repository not found. Run 'n0dm init' first."
        return 1
    fi

    # Check if remote already exists
    local existing_remote
    existing_remote=$(git --git-dir="$yadm_git_dir" remote get-url origin 2>/dev/null || echo "")
    if [[ -n "$existing_remote" ]]; then
        print_warn "Remote already configured: $existing_remote"
        if [[ "${N0DM_YES:-false}" != "true" ]]; then
            read -p "Replace it? [y/N] " -n 1 -r confirm
            read -r _ || true
            echo
            [[ $confirm =~ ^[Yy]$ ]] || { print_info "Keeping existing remote"; return 0; }
        fi
    fi

    # If no repo specified, prompt for it
    if [[ -z "$repo" ]]; then
        print_info "Connect to a GitHub repository"
        echo "  Format: username/repo  (e.g., alice/dotfiles)"
        echo "  Or full URL: https://github.com/alice/dotfiles.git"
        echo
        read -p "Repository: " -r repo
    fi

    [[ -z "$repo" ]] && { print_err "No repository specified"; return 1; }

    # Convert short form to GitHub URL if needed
    local remote_url
    if [[ "$repo" =~ ^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$ ]]; then
        remote_url="https://github.com/${repo}.git"
    elif [[ "$repo" =~ ^git@github\.com: ]]; then
        remote_url="$repo"
    elif [[ "$repo" =~ ^https?:// ]]; then
        remote_url="$repo"
    else
        print_err "Invalid repository format. Use 'username/repo' or full URL."
        return 1
    fi

    # Add or set the remote
    if [[ -n "$existing_remote" ]]; then
        git --git-dir="$yadm_git_dir" remote set-url origin "$remote_url"
    else
        git --git-dir="$yadm_git_dir" remote add origin "$remote_url"
    fi

    print_ok "Remote configured: $remote_url"
    print_info "Next steps:"
    echo "  1. Create the repository on GitHub (if not exists)"
    echo "  2. Run: n0dm push -u origin"
}

#--- Enhanced Init with Remote Setup -------------------------------------------
n0dm_init() {
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)

    if [[ -d "$yadm_git_dir" ]]; then
        print_warn "Yadm repository already exists at: $yadm_git_dir"
        if [[ "${N0DM_YES:-false}" != "true" ]]; then
            read -p "Re-initialize? This will not affect your files. [y/N] " -n 1 -r
            echo
            [[ $REPLY =~ ^[Yy]$ ]] || { print_info "Keeping existing repository"; return 0; }
        fi
    fi

    # Run yadm init
    print_info "Initializing yadm repository..."
    yadm init -f 2>/dev/null || yadm init

    print_ok "Local repository initialized"

    # Create .gitignore template if it doesn't exist
    if [[ ! -f "$HOME/.gitignore" ]]; then
        print_info "Creating default .gitignore..."
        cat > "$HOME/.gitignore" <<'IGNORE_EOF'
# Ignore everything by default
/*

# Whitelist dotfiles you want to track
!.bashrc
!.bash_profile
!.zshrc
!.profile
!.bash_logout
!.gitconfig
!.inputrc
!.tmux.conf
!.vimrc
!.nvim/
!.config/
!.local/bin/
!.local/share/n0dm/

# But ignore these common large/problematic directories
.cache/
.bun/
.npm/
.pnpm/
.yarn/
node_modules/
Downloads/
Pictures/
Videos/
Music/
Public/
.local/share/Trash/
.local/state/
.local/lib/
IGNORE_EOF
        print_ok "Created ~/.gitignore - customize to whitelist your dotfiles"
        print_info "Add it first: yadm add ~/.gitignore"
    fi

    # Prompt for remote setup
    if [[ "${N0DM_YES:-false}" != "true" ]]; then
        echo
        print_info "Connect to a GitHub repository for backup and sync?"
        read -p "Set up remote? [Y/n] " -n 1 -r confirm
        # Consume the newline left in buffer
        read -r _ || true
        echo
        if [[ $confirm =~ ^[Yy]$ || "$confirm" == "" ]]; then
            echo
            print_info "Enter your GitHub repository"
            echo "  Format: username/repo  (e.g., alice/dotfiles)"
            echo
            read -p "Repository: " -r repo

            if [[ -n "$repo" ]]; then
                local remote_url
                if [[ "$repo" =~ ^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$ ]]; then
                    remote_url="https://github.com/${repo}.git"
                elif [[ "$repo" =~ ^git@github\.com: ]]; then
                    remote_url="$repo"
                elif [[ "$repo" =~ ^https?:// ]]; then
                    remote_url="$repo"
                else
                    print_err "Invalid format, skipping remote setup"
                    return 0
                fi

                git --git-dir="$yadm_git_dir" remote add origin "$remote_url" 2>/dev/null || \
                    git --git-dir="$yadm_git_dir" remote set-url origin "$remote_url"

                print_ok "Remote configured: $remote_url"
                echo
                print_info "Next steps:"
                echo "  1. Create the repository on GitHub:"
                echo "     gh repo create ${repo} --public --push"
                echo "  2. Then run: n0dm sync \"Initial commit\""
            else
                print_info "Skipping remote setup. Use 'n0dm connect' later."
            fi
        fi
    fi

    print_info "Run 'n0dm status' to see repository state"
}

#--- Clone Repository ----------------------------------------------------------
n0dm_clone() {
    local repo="${1:-}"
    local force=false
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    
    # Parse flags
    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=true; shift ;;
            -*) shift ;;
            *) shift ;;
        esac
    done
    
    # Check if repo argument provided
    if [[ -z "$repo" ]]; then
        print_err "No repository specified."
        print_info "Usage: n0dm clone <repo> [-f]"
        print_info "Example: n0dm clone noeltz/n0ctachiri"
        print_info "        n0dm clone https://github.com/noeltz/n0ctachiri.git"
        return 1
    fi
    
    # Check if local repo already exists
    if [[ -d "$yadm_git_dir" ]]; then
        if [[ "$force" != "true" ]]; then
            print_err "Git repo already exists. [$yadm_git_dir]"
            print_info "Use '-f' to force overwrite (will delete local data!)"
            return 1
        else
            print_warn "Force flag used - removing existing repo..."
            rm -rf "$yadm_git_dir"
        fi
    fi
    
    # Convert short format to full URL if needed
    local remote_url
    if [[ "$repo" =~ ^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$ ]]; then
        remote_url="https://github.com/${repo}.git"
    elif [[ "$repo" =~ ^git@github\.com: ]]; then
        remote_url="$repo"
    elif [[ "$repo" =~ ^https?:// ]]; then
        remote_url="$repo"
    else
        print_err "Invalid repository format. Use 'username/repo' or full URL."
        return 1
    fi
    
    print_info "Cloning $remote_url..."
    
    # Clone the repository using yadm
    if ! yadm clone "$remote_url" 2>&1; then
        print_err "Unable to clone the repository"
        print_info "Make sure:"
        echo "  1. You're authenticated with GitHub (run: gh auth login)"
        echo "  2. The repository exists and is accessible"
        echo "  3. You have network connectivity"
        return 1
    fi
    
    print_ok "Repository cloned successfully"
    
    # Checkout files to home directory
    print_info "Checking out files to home directory..."
    local checkout_output
    checkout_output=$(yadm checkout . 2>&1)
    if echo "$checkout_output" | grep -q "did not match any file"; then
        print_warn "No files checked out - repository may be empty"
    elif echo "$checkout_output" | grep -q "left unmodified\|different"; then
        print_warn "Local files differ from repository"
        print_info "To overwrite local files, run: yadm checkout . --force"
        print_info "To keep local files, run: n0dm status to review differences"
    fi
    
    print_ok "Clone complete!"
    print_info "Run 'n0dm status' to see the repository state"
}

#--- Schedule: Systemd Timer Setup ---------------------------------------------
n0dm_schedule() {
    local action="${1:-}"
    local frequency="${2:-hourly}"
    local service_dir="$HOME/.config/systemd/user"
    local timer_file="$service_dir/n0dm-sync.timer"
    local service_file="$service_dir/n0dm-sync.service"
    
    # Check if systemd is available
    if ! command -v systemctl &>/dev/null; then
        print_err "systemd is not available on this system"
        return 1
    fi
    
    # Handle different actions
    case "$action" in
        off|disable|stop)
            print_info "Disabling auto-sync timer..."
            systemctl --user stop n0dm-sync.timer 2>/dev/null || true
            systemctl --user disable n0dm-sync.timer 2>/dev/null || true
            print_ok "Auto-sync disabled"
            return 0
            ;;
        status)
            if systemctl --user is-enabled n0dm-sync.timer &>/dev/null; then
                print_info "Auto-sync is enabled"
                systemctl --user status n0dm-sync.timer --no-pager || true
            else
                print_warn "Auto-sync is not enabled"
                print_info "Run 'n0dm schedule' to enable it"
            fi
            return 0
            ;;
        ""|-h|--help|help)
            echo "Usage: n0dm schedule [action] [frequency]"
            echo ""
            echo "Actions:"
            echo "  (none)     Enable auto-sync (default: hourly)"
            echo "  hourly     Enable hourly sync"
            echo "  daily      Enable daily sync"
            echo "  weekly     Enable weekly sync"
            echo "  off        Disable auto-sync"
            echo "  status     Check if auto-sync is enabled"
            echo ""
            echo "Examples:"
            echo "  n0dm schedule           # Enable hourly auto-sync"
            echo "  n0dm schedule daily     # Enable daily sync"
            echo "  n0dm schedule off       # Disable auto-sync"
            return 0
            ;;
    esac
    
    # Determine frequency
    case "$action" in
        hourly) frequency="hourly" ;;
        daily) frequency="daily" ;;
        weekly) frequency="weekly" ;;
        *)
            # If first arg is not a valid action, treat it as frequency
            if [[ "$action" =~ ^(hourly|daily|weekly)$ ]]; then
                frequency="$action"
            else
                frequency="hourly"
            fi
            ;;
    esac
    
    # Set interval based on frequency
    local interval
    case "$frequency" in
        hourly)
            interval="OnBootSec=5min\nOnUnitActiveSec=60min"
            ;;
        daily)
            interval="OnBootSec=10min\nOnUnitActiveSec=1d"
            ;;
        weekly)
            interval="OnBootSec=10min\nOnUnitActiveSec=1w"
            ;;
    esac
    
    # Create service directory
    mkdir -p "$service_dir"
    
    # Create service file
    cat > "$service_file" <<EOF
[Unit]
Description=N0DM Smart Sync
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=${HOME}/.local/bin/n0dm update --yes
ExecStart=${HOME}/.local/bin/n0dm sync --yes
Environment="PATH=/usr/local/bin:/usr/bin:/bin"
EOF
    
    # Create timer file
    cat > "$timer_file" <<EOF
[Unit]
Description=N0DM Auto-Sync Timer ($frequency)

[Timer]
$interval
Persistent=true

[Install]
WantedBy=timers.target
EOF
    
    print_info "Created systemd timer: $frequency"
    
    # Reload and enable
    print_info "Enabling timer..."
    systemctl --user daemon-reload
    systemctl --user enable --now n0dm-sync.timer
    
    if systemctl --user is-enabled n0dm-sync.timer &>/dev/null; then
        print_ok "Auto-sync enabled ($frequency)"
        print_info "Next sync will happen in the background"
    else
        print_err "Failed to enable timer"
        return 1
    fi
}

#--- Hook: Pacman Integration -------------------------------------------------
n0dm_hook() {
    local action="${1:-}"
    local hook_dir="/etc/pacman.d/hooks"
    local hook_file="$hook_dir/n0dm-sync.hook"
    local n0dm_path="$(command -v n0dm 2>/dev/null || echo "$HOME/.local/bin/n0dm")"
    
    case "$action" in
        install)
            # Check if we have sudo
            if [[ $EUID -ne 0 ]] && ! sudo -v 2>/dev/null; then
                print_err "Root privileges required. Run with sudo or install manually."
                return 1
            fi
            
            # Check if hook already exists
            if [[ -f "$hook_file" ]]; then
                print_warn "Hook already exists at $hook_file"
                read -p "Overwrite? [y/N] " -n 1 -r
                echo
                [[ $REPLY =~ ^[Yy]$ ]] || { print_info "Keeping existing hook"; return 0; }
            fi
            
            # Create hook directory if needed
            sudo mkdir -p "$hook_dir"
            
            # Create hook file
            sudo tee "$hook_file" > /dev/null <<EOF
[Trigger]
Operation = Upgrade
Operation = Install
Operation = Remove
Type = Package
Target = *

[Action]
Description = Syncing dotfiles after pacman transaction...
When = PostTransaction
Exec = /usr/bin/su - ${USER} -c '${n0dm_path} update --yes && ${n0dm_path} sync --yes'
EOF
            
            print_ok "Hook installed: $hook_file"
            print_info "n0dm will update and sync after every pacman operation"
            return 0
            ;;
        uninstall|remove)
            if [[ $EUID -ne 0 ]] && ! sudo -v 2>/dev/null; then
                print_err "Root privileges required."
                return 1
            fi
            
            if [[ -f "$hook_file" ]]; then
                sudo rm -f "$hook_file"
                print_ok "Hook removed: $hook_file"
            else
                print_warn "No hook found at $hook_file"
            fi
            return 0
            ;;
        status)
            if [[ -f "$hook_file" ]]; then
                print_ok "Hook is installed: $hook_file"
                echo
                echo "Content:"
                sudo cat "$hook_file"
            else
                print_warn "No hook installed"
                print_info "Run 'n0dm hook install' to add it"
            fi
            return 0
            ;;
        ""|-h|--help|help)
            echo "Usage: n0dm hook [action]"
            echo ""
            echo "Actions:"
            echo "  install    Install pacman hook (requires sudo)"
            echo "  uninstall  Remove pacman hook (requires sudo)"
            echo "  status     Check if hook is installed"
            echo ""
            echo "Examples:"
            echo "  n0dm hook install    # Install hook (runs sync after pacman)"
            echo "  n0dm hook status     # Check hook status"
            echo "  n0dm hook uninstall  # Remove hook"
            echo ""
            echo "Note: Works with pacman, paru, yay, and other libalpm-based helpers."
            return 0
            ;;
        *)
            print_err "Unknown action: $action"
            echo "Run 'n0dm hook' for usage"
            return 1
            ;;
    esac
}

#--- Atomic Self-Update --------------------------------------------------------
self_update() {
    print_info "Checking for updates..."

    # Resolve actual path (handle symlinks)
    local actual_path; actual_path=$(realpath "$0" 2>/dev/null || echo "$0")
    local script_dir; script_dir=$(dirname "$actual_path")
    local temp_file; temp_file=$(mktemp -p "$script_dir" .n0dm-update.XXXXXX)
    local temp_checksum; temp_checksum=$(mktemp -p "$script_dir" .n0dm-checksum.XXXXXX)

    # Download the update
    if ! curl -fsSL "$N0DM_UPDATE_URL" -o "$temp_file" 2>/dev/null; then
        rm -f "$temp_file" "$temp_checksum"
        print_err "Failed to download update"
        print_info "Make sure you have internet connectivity"
        return 1
    fi

    # Download and verify checksum (best effort - don't fail if unavailable)
    local checksum_verified=false
    if curl -fsSL "$N0DM_CHECKSUM_URL" -o "$temp_checksum" 2>/dev/null; then
        local expected_checksum; expected_checksum=$(awk '{print $1}' "$temp_checksum" 2>/dev/null)
        if [[ -n "$expected_checksum" ]]; then
            local actual_checksum; actual_checksum=$(sha256sum "$temp_file" 2>/dev/null | awk '{print $1}')
            if [[ "$expected_checksum" == "$actual_checksum" ]]; then
                checksum_verified=true
            else
                rm -f "$temp_file" "$temp_checksum"
                print_err "Checksum verification failed!"
                print_warn "The downloaded file may be corrupted or tampered with"
                print_info "Expected: $expected_checksum"
                print_info "Got:      $actual_checksum"
                return 1
            fi
        fi
        rm -f "$temp_checksum"
    else
        print_warn "Could not download checksum file (verification skipped)"
        rm -f "$temp_checksum"
    fi

    local current_version; current_version=$(grep "^readonly N0DM_VERSION=" "$actual_path" 2>/dev/null | head -1 | cut -d'"' -f2)
    local new_version; new_version=$(grep "^readonly N0DM_VERSION=" "$temp_file" 2>/dev/null | head -1 | cut -d'"' -f2)

    [[ -z "$current_version" ]] && current_version="unknown"
    [[ -z "$new_version" ]] && { print_err "Failed to determine remote version"; rm -f "$temp_file"; return 1; }

    if [[ "$new_version" != "$current_version" ]]; then
        print_info "New version available: $new_version (current: $current_version)"
        if [[ "$checksum_verified" == "true" ]]; then
            print_info "Checksum verified ✓"
        fi
        if [[ "${N0DM_YES:-false}" == "true" ]]; then
            auto_confirm="y"
        else
            read -p "Install update? [y/N] " -n 1 -r auto_confirm
            echo
        fi

        if [[ $auto_confirm =~ ^[Yy]$ ]]; then
            chmod +x "$temp_file"

            # Backup current version before replacing
            local backup_file="${actual_path}.backup.$(date +%s)"
            cp "$actual_path" "$backup_file"

            if cp "$temp_file" "$actual_path" 2>/dev/null; then
                rm -f "$temp_file"
                rm -f "$backup_file"
                print_ok "Updated to version $new_version"
                print_info "Restarting n0dm..."
                exec "$actual_path" version
            else
                # ROLLBACK on failure
                print_err "Update failed - rolling back..."
                cp "$backup_file" "$actual_path" 2>/dev/null || true
                rm -f "$backup_file"
                rm -f "$temp_file"
                print_err "Rollback complete. Please try again."
                return 1
            fi
        else
            rm -f "$temp_file"
            print_info "Update cancelled"
        fi
    else
        print_ok "Already running the latest version ($current_version)"
        rm -f "$temp_file"
    fi
}

#--- Track Files (wrapper for yadm add) ----------------------------------------
n0dm_track() {
    if [[ $# -eq 0 ]]; then
        print_err "No files specified."
        print_info "Usage: n0dm track <file> [file...]"
        print_info "Example: n0dm track ~/.bashrc ~/.config/nvim/"
        return 1
    fi

    check_yadm

    # Convert paths to relative (remove ~ and /home/user prefix)
    local files=()
    local dirs=()
    local root_files=()
    for file in "$@"; do
        # Expand ~ if present
        file="${file/#\~/$HOME}"
        # Make absolute if not already
        [[ "$file" != /* ]] && file="$(pwd)/$file"
        # Convert to relative path from HOME
        local rel_path="${file#$HOME/}"
        files+=("$rel_path")
        # Track directories and root-level files separately for .gitignore handling
        if [[ -d "$file" ]]; then
            dirs+=("$rel_path")
        elif [[ "$rel_path" != */* ]]; then
            # Root-level file (no slash in relative path)
            root_files+=("$rel_path")
        fi
    done

    # Auto-update .gitignore for directories and root-level files (smart whitelist management)
    local gitignore_updated=false
    if [[ -f "$HOME/.gitignore" ]]; then
        # Handle directories
        if [[ ${#dirs[@]} -gt 0 ]]; then
            for dir in "${dirs[@]}"; do
                # Check if directory is already un-ignored in .gitignore
                if ! grep -q "^!${dir}" "$HOME/.gitignore" 2>/dev/null; then
                    # Add un-ignore patterns for the directory and its contents
                    echo "!${dir}/" >> "$HOME/.gitignore"
                    echo "!${dir}/*" >> "$HOME/.gitignore"
                    print_info "Added '$dir' to .gitignore whitelist"
                    gitignore_updated=true
                fi
            done
        fi
        # Handle root-level files
        if [[ ${#root_files[@]} -gt 0 ]]; then
            for rf in "${root_files[@]}"; do
                # Check if file is already un-ignored in .gitignore
                if ! grep -q "^!${rf}$" "$HOME/.gitignore" 2>/dev/null; then
                    echo "!${rf}" >> "$HOME/.gitignore"
                    print_info "Added '$rf' to .gitignore whitelist"
                    gitignore_updated=true
                fi
            done
        fi
    fi

    # Stage .gitignore if it was modified
    if [[ "$gitignore_updated" == "true" ]]; then
        (cd "$HOME" && yadm add .gitignore)
    fi

    print_info "Tracking ${#files[@]} file(s)..."
    # Run yadm add from HOME directory so relative paths work
    (cd "$HOME" && yadm add "${files[@]}")
    print_ok "Added to tracking: ${files[*]}"
    if [[ "$gitignore_updated" == "true" ]]; then
        print_info ".gitignore updated and staged"
    fi
    print_info "Run 'n0dm sync' to commit and push"
}

#--- Untrack Files (wrapper for yadm rm --cached) ------------------------------
n0dm_untrack() {
    if [[ $# -eq 0 ]]; then
        print_err "No files specified."
        print_info "Usage: n0dm untrack <file> [file...]"
        print_info "Example: n0dm untrack ~/.bashrc ~/.config/cache/"
        return 1
    fi

    check_yadm

    # Convert paths to relative (remove ~ and /home/user prefix)
    local files=()
    for file in "$@"; do
        # Expand ~ if present
        file="${file/#\~/$HOME}"
        # Make absolute if not already
        [[ "$file" != /* ]] && file="$(pwd)/$file"
        # Convert to relative path from HOME
        local rel_path="${file#$HOME/}"
        files+=("$rel_path")
    done

    # Check if files are actually tracked (in HEAD)
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    local tracked_files=()
    local unstaged_files=()
    
    for file in "${files[@]}"; do
        if git --git-dir="$yadm_git_dir" rev-parse HEAD:"$file" &>/dev/null; then
            tracked_files+=("$file")
        else
            unstaged_files+=("$file")
        fi
    done

    if [[ ${#tracked_files[@]} -gt 0 ]]; then
        print_info "Removing from tracking (keeping files in place)..."

        # Check if any files are directories (need -r flag)
        local dirs=() regular_files=()
        for f in "${tracked_files[@]}"; do
            if [[ -d "$HOME/$f" ]]; then
                dirs+=("$f")
            else
                regular_files+=("$f")
            fi
        done

        # Remove files first
        if [[ ${#regular_files[@]} -gt 0 ]]; then
            (cd "$HOME" && yadm rm --cached "${regular_files[@]}")
        fi

        # Remove directories with -r flag
        if [[ ${#dirs[@]} -gt 0 ]]; then
            (cd "$HOME" && yadm rm -r --cached "${dirs[@]}")
        fi
        
        print_ok "Untracked: ${tracked_files[*]}"
        print_info "Files remain in your home directory."
        
        # Commit the removal immediately
        print_info "Committing removal..."
        if (cd "$HOME" && yadm commit -m "n0dm untrack: ${tracked_files[*]}"); then
            print_ok "Removal committed!"
            print_info "Run 'n0dm sync' to push this change to remote."
        else
            print_warn "Nothing to commit (check if files were actually tracked)"
        fi
    fi
    
    # Handle files that were staged but not yet committed
    if [[ ${#unstaged_files[@]} -gt 0 ]]; then
        print_info "Removing unstaged files from index..."
        (cd "$HOME" && yadm rm --cached "${unstaged_files[@]}")
        print_ok "Removed from staging (never committed): ${unstaged_files[*]}"
        print_info "Files remain in your home directory."
    fi
    
    if [[ ${#tracked_files[@]} -eq 0 && ${#unstaged_files[@]} -eq 0 ]]; then
        print_warn "None of the specified files are tracked."
    fi
}

#--- Yadm Passthrough (ALL native commands) ------------------------------------
# This function passes ANY command directly to yadm, preserving all native behavior
yadm_passthrough() {
    check_yadm
    yadm "$@"
}

#--- Enhanced Status (yadm status + n0dm info) ---------------------------------
n0dm_status() {
    # First, show native yadm status (passthrough behavior)
    echo -e "${BOLD}=== Yadm Repository Status ===${RESET}"
    yadm status "$@" 2>/dev/null || print_warn "Yadm not initialized"
    echo

    # Then, append n0dm-specific backup info
    echo -e "${BOLD}=== N0DM Backup Status ===${RESET}"
    local count=0
    if [[ -d "$N0DM_BACKUP_DIR" ]]; then
        count=$(find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
    fi
    echo "  Backups stored: $count / $MAX_BACKUPS"
    echo "  Retention: $BACKUP_RETENTION_DAYS days"
    echo "  Last backup epoch: $(get_last_backup_epoch)"
    echo "  Backup directory: $N0DM_BACKUP_DIR"
    echo

    echo -e "${BOLD}=== N0DM Info ===${RESET}"
    echo "  Version: $N0DM_VERSION"
    echo "  Script: $(realpath "$0")"

    # Check for remote
    local yadm_git_dir; yadm_git_dir=$(get_yadm_git_dir)
    if [[ -d "$yadm_git_dir" ]]; then
        local remote_url
        remote_url=$(git --git-dir="$yadm_git_dir" remote get-url origin 2>/dev/null || echo "")
        if [[ -n "$remote_url" ]]; then
            echo -e "  ${GREEN}✓ Remote configured:${RESET} $remote_url"
        else
            echo -e "  ${YELLOW}⚠ No remote configured${RESET}"
            echo -e "     ${BLUE}→ Run:${RESET} n0dm connect <user/repo>"
        fi
    fi

    # Smart backup preview
    if needs_smart_backup 2>/dev/null; then
        echo -e "  ${YELLOW}⚠ Tracked files have changed since last backup${RESET}"
    else
        echo -e "  ${GREEN}✓ Tracked files unchanged (next sync will skip backup)${RESET}"
    fi
}

#--- Enhanced List (yadm list + optional backup summary) -----------------------
n0dm_list() {
    # Pass through to yadm's native list command
    yadm list "$@"
    
    # Optional: show brief backup summary after list (non-intrusive)
    if [[ -d "$N0DM_BACKUP_DIR" ]]; then
        local count; count=$(find "$N0DM_BACKUP_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
        if [[ "$count" -gt 0 ]]; then
            echo
            print_notice "Tip: $count backup(s) available. Use 'n0dm backups' to list or 'n0dm restore <id>' to recover."
        fi
    fi
}

