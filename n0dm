#--- Main CLI ------------------------------------------------------------------
main() {
    ensure_dirs
    load_config
    
    # Parse global flags first
    local no_backup=false dry_run=false yes_mode=false verbose=false force=false safe_mode=false
    local args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-backup) no_backup=true; shift ;;
            --dry-run) dry_run=true; shift ;;
            --yes) yes_mode=true; export N0DM_YES=true; shift ;;
            --verbose) verbose=true; shift ;;
            --force) force=true; shift ;;
            --safe) safe_mode=true; shift ;;
            -*) args+=("$1"); shift ;;
            *) args+=("$1"); shift ;;
        esac
    done

    set -- "${args[@]}"
    local cmd="${1:-help}"; shift || true

    case "$cmd" in
        #--- Enhanced N0DM Commands ---
        init)
            n0dm_init "$@"
            ;;
        clone)
            n0dm_clone "$@"
            ;;
        sync)
            n0dm_safe_sync "${1:-Auto-sync}" "$no_backup" "$dry_run" "$force" "$safe_mode"
            ;;
        track)
            n0dm_track "$@"
            ;;
        untrack)
            n0dm_untrack "$@"
            ;;
        backup)
            create_backup "${1:-manual}"
            ;;
        restore)
            [[ -z "${1:-}" ]] && { list_backups; exit 0; }
            restore_backup "$1"
            ;;
        backups)
            list_backups
            ;;
        cleanup)
            cleanup_backups
            print_ok "Cleanup complete"
            ;;
        conflicts)
            n0dm_check_conflicts
            ;;
        health|doctor)
            n0dm_health "$@"
            ;;
        status)
            n0dm_status "$@"
            ;;
        update|upgrade|self-update)
            self_update
            ;;
        mergetool)
            check_yadm
            yadm mergetool "$@"
            ;;
        list)
            n0dm_list "$@"
            ;;
        #--- Access native yadm commands that conflict ---
        yadm-restore)
            # Access native yadm restore when n0dm 'restore' means backup restore
            check_yadm
            yadm restore "$@"
            ;;
        yadm-reset)
            check_yadm
            yadm reset "$@"
            ;;
        #--- N0DM-specific commands ---
        help)
            show_help
            ;;
        version)
            echo "n0dm version ${N0DM_VERSION}"
            ;;
        connect)
            n0dm_connect "$@"
            ;;
        schedule)
            n0dm_schedule "$@"
            ;;
        hook)
            n0dm_hook "$@"
            ;;
        #--- All other commands: Full passthrough to Yadm ---
        *)
            # This catches ALL native yadm commands:
            # init, clone, add, commit, push, pull, merge, branch, remote,
            # checkout, reset, restore, clean, config, log, diff, enter,
            # alt, encrypt, decrypt, bootstrap, etc.
            yadm_passthrough "$cmd" "$@"
            ;;
    esac
}

main "$@"
